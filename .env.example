# .env.example — copy this to .env and fill in your values
# (Never commit your actual .env to GitHub!)

# Google Gemini LLM
GEMINI_API_KEY=your_gemini_api_key_here

# AWS S3 (only needed if using --real-s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=ap-south-1

# Legacy CRM API (only needed if using --real-crm)
CRM_BASE_URL=https://your-crm-domain.com/api/v1
CRM_API_KEY=your_crm_api_key

# Testing: simulate CRM failures to test retry logic (0.0 = never fail, 0.5 = 50% chance)
MOCK_FAIL_RATE=0.0
